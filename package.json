{
  "name": "poe2-build-planner",
  "version": "1.0.6",
  "description": "An editor and creator for Path of Exile 2 Build Planner files",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "update-tree": "node scripts/update_skilltree.js",
    "update-gems": "node scripts/update_gems.js",
    "build": "electron-builder"
  },
  "keywords": [
    "poe2",
    "pathofexile",
    "build-planner"
  ],
  "author": "Srlimao",
  "repository": {
    "type": "git",
    "url": "https://github.com/Srlimao/Poe2Builder.git"
  },
  "license": "ISC",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.poe2buildplanner.app",
    "productName": "PoE2 Build Planner",
    "directories": {
      "output": "releases"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}